{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "rig config",
    "description": "Configuration file for rig - a declarative dev environment bootstrapper",
    "type": "object",
    "required": ["name", "version", "steps"],
    "properties": {
        "$schema": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" },
        "meta": { "$ref": "#/definitions/config_meta" },
        "bundle": { "$ref": "#/definitions/bundle_meta" },
        "steps": { "type": "array", "items": { "$ref": "#/definitions/step" } }
    },
    "definitions": {
        "bundle_meta": {
            "type": "object",
            "description": "Bundle-specific settings, used when the manifest ships inside a .rig archive",
            "additionalProperties": false,
            "properties": {
                "extract-to": {
                    "description": "Where to extract the bundle before running (default: tmp)",
                    "oneOf": [
                        { "type": "string", "enum": ["tmp", "cwd", "home"] },
                        {
                            "type": "object",
                            "required": ["path"],
                            "additionalProperties": false,
                            "properties": {
                                "path": { "type": "string", "description": "Explicit extraction path (~ expanded)" }
                            }
                        }
                    ]
                },
                "cleanup": {
                    "type": "string",
                    "enum": ["always", "on-success", "never"],
                    "default": "on-success",
                    "description": "When to delete the staging directory: always, only on success, or never"
                },
                "binary": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Glob patterns (relative to bundle root) for files copied byte-for-byte (no {{...}} substitution in contents)"
                }
            }
        },
        "config_meta": {
            "type": "object",
            "description": "Top-level execution defaults",
            "properties": {
                "log": { "type": "string", "description": "Path to log file (supports {{variables}})" },
                "silent": {
                    "type": "array",
                    "items": { "type": "string", "enum": ["stdout", "stderr"] },
                    "description": "Global default: suppress output"
                },
                "sudo": { "type": "boolean", "default": false, "description": "Global default: run shell commands with sudo" },
                "retries": { "type": "integer", "minimum": 0, "description": "Global default: auto-retry count on failure" },
                "retry-delay": { "type": "number", "minimum": 0, "description": "Global default: seconds before each retry" },
                "vars": {
                    "type": "object",
                    "description": "Variable defaults (may be nested; overridden by --set). Access via dot notation: {{super.mario.bros}}"
                }
            }
        },
        "step": {
            "type": "object",
            "required": ["name", "action"],
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Unique step ID for referencing"
                },
                "name": { "type": "string" },
                "description": { "type": "string" },
                "action": { "$ref": "#/definitions/action" },
                "on-success": {
                    "$ref": "#/definitions/step_refs",
                    "description": "Run on exit 0 (unless overridden by on-return)"
                },
                "on-failure": {
                    "$ref": "#/definitions/step_refs",
                    "description": "Run on non-zero exit (unless overridden by on-return)"
                },
                "on-return": {
                    "type": "object",
                    "description": "Map exit codes to step refs. Overrides on-success/on-failure. _ = wildcard.",
                    "additionalProperties": {
                        "$ref": "#/definitions/step_refs"
                    }
                },
                "then": {
                    "type": "array",
                    "description": "Sub-steps that run after the action succeeds (or is handled)",
                    "items": {
                        "oneOf": [
                            {
                                "type": "string",
                                "description": "Step ID reference"
                            },
                            { "$ref": "#/definitions/step" }
                        ]
                    }
                },
                "meta": { "$ref": "#/definitions/meta" }
            }
        },
        "step_refs": {
            "oneOf": [
                { "type": "string", "description": "Single step ID" },
                { "$ref": "#/definitions/step" },
                {
                    "type": "array",
                    "items": {
                        "oneOf": [
                            { "type": "string", "description": "Step ID" },
                            { "$ref": "#/definitions/step" }
                        ]
                    }
                }
            ]
        },
        "step_ref_or_array": {
            "description": "A single step reference (ID string or inline step) or an array of them",
            "oneOf": [
                { "type": "string" },
                { "$ref": "#/definitions/step" },
                {
                    "type": "array",
                    "items": {
                        "oneOf": [
                            { "type": "string" },
                            { "$ref": "#/definitions/step" }
                        ]
                    }
                }
            ]
        },
        "meta": {
            "type": "object",
            "properties": {
                "optional": {
                    "type": "boolean",
                    "default": false,
                    "description": "Only runs when referenced by ID"
                },
                "fallible": {
                    "type": "boolean",
                    "default": false,
                    "description": "Failure doesn't halt the run"
                },
                "sudo": {
                    "type": "boolean",
                    "default": false,
                    "description": "Run shell commands with sudo"
                },
                "silent": {
                    "type": "array",
                    "items": { "type": "string", "enum": ["stdout", "stderr"] },
                    "description": "Suppress output (shown with --verbose)"
                },
                "retries": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Auto-retry count on failure (overrides global)"
                },
                "retry-delay": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Seconds to wait before each retry"
                }
            }
        },
        "action": {
            "type": "object",
            "required": ["kind"],
            "oneOf": [
                { "$ref": "#/definitions/action_shell" },
                { "$ref": "#/definitions/action_git" },
                { "$ref": "#/definitions/action_fs_create" },
                { "$ref": "#/definitions/action_fs_symlink" },
                { "$ref": "#/definitions/action_fs_copy" },
                { "$ref": "#/definitions/action_fs_move" },
                { "$ref": "#/definitions/action_fs_delete" },
                { "$ref": "#/definitions/action_io_write" },
                { "$ref": "#/definitions/action_io_read" },
                { "$ref": "#/definitions/action_var_command" },
                { "$ref": "#/definitions/action_var_file" },
                { "$ref": "#/definitions/action_var_from" },
                { "$ref": "#/definitions/action_var_to" },
                { "$ref": "#/definitions/action_cond" }
            ]
        },
        "action_shell": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "shell" },
                "commands": {
                    "oneOf": [
                        { "type": "string" },
                        { "type": "array", "items": { "type": "string" } }
                    ],
                    "description": "Commands run via sh -c (single string or array)"
                },
                "dir": {
                    "type": "string",
                    "description": "Working directory (~ expanded)"
                },
                "env": {
                    "type": "object",
                    "additionalProperties": { "type": "string" },
                    "description": "Env vars"
                }
            },
            "required": ["kind", "commands"]
        },
        "action_git": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "git" },
                "repo": {
                    "type": "string",
                    "description": "Git repository URL"
                },
                "dest": {
                    "type": "string",
                    "description": "Clone destination (~ expanded)"
                },
                "on-conflict": {
                    "type": "string",
                    "enum": ["skip", "pull", "fail"],
                    "default": "skip",
                    "description": "What to do if dest exists"
                }
            },
            "required": ["kind", "repo", "dest"]
        },
        "action_fs_create": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "fs" },
                "create": {
                    "type": "object",
                    "required": ["path"],
                    "properties": {
                        "path": { "$ref": "#/definitions/path_spec" },
                        "recurse": { "type": "boolean", "default": false },
                        "content": {
                            "type": "string",
                            "description": "Inline content to write (files only)"
                        },
                        "expand": { "$ref": "#/definitions/expand" }
                    }
                },
                "if-exists": { "$ref": "#/definitions/condition" },
                "if-not-exists": { "$ref": "#/definitions/condition" }
            },
            "required": ["kind", "create"]
        },
        "action_fs_symlink": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "fs" },
                "symlink": {
                    "type": "object",
                    "required": ["from", "to"],
                    "properties": {
                        "from": { "type": "string" },
                        "to": { "type": "string" },
                        "expand": { "$ref": "#/definitions/expand" }
                    }
                },
                "if-exists": { "$ref": "#/definitions/condition" }
            },
            "required": ["kind", "symlink"]
        },
        "action_fs_copy": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "fs" },
                "copy": {
                    "type": "object",
                    "required": ["from", "to"],
                    "properties": {
                        "from": { "type": "string" },
                        "to": { "type": "string" },
                        "expand": { "$ref": "#/definitions/expand" }
                    }
                },
                "if-exists": { "$ref": "#/definitions/condition" },
                "if-not-exists": { "$ref": "#/definitions/condition" }
            },
            "required": ["kind", "copy"]
        },
        "action_fs_move": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "fs" },
                "move": {
                    "type": "object",
                    "required": ["from", "to"],
                    "properties": {
                        "from": { "type": "string" },
                        "to": { "type": "string" },
                        "expand": { "$ref": "#/definitions/expand" }
                    }
                },
                "if-exists": { "$ref": "#/definitions/condition" },
                "if-not-exists": { "$ref": "#/definitions/condition" }
            },
            "required": ["kind", "move"]
        },
        "action_fs_delete": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "fs" },
                "delete": {
                    "type": "object",
                    "required": ["path"],
                    "properties": {
                        "path": { "$ref": "#/definitions/path_spec" },
                        "recurse": { "type": "boolean", "default": false },
                        "expand": { "$ref": "#/definitions/expand" }
                    }
                },
                "if-not-exists": { "$ref": "#/definitions/condition" }
            },
            "required": ["kind", "delete"]
        },
        "action_io_write": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "io" },
                "level": { "type": "string", "enum": ["log", "info", "warn", "error"], "description": "Message severity level" },
                "message": { "type": "string", "description": "Message text" },
                "markup": { "type": "boolean", "default": false, "description": "Parse message as aml markup" }
            },
            "required": ["kind", "level", "message"]
        },
        "action_io_read": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "io" },
                "read": { "type": "string", "description": "Target @var to store the line read from stdin" },
                "prompt": { "type": "string", "description": "Prompt text shown before reading" },
                "default": { "type": "string", "description": "Value used when the user enters an empty line" },
                "secret": { "type": "boolean", "default": false, "description": "Mask input with * per keystroke; display captured value as ****" }
            },
            "required": ["kind", "read"]
        },
        "action_var_command": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "var" },
                "name": { "type": "string", "description": "Variable name (must start with @ for runtime mutability)" },
                "command": { "type": "string", "description": "Shell command; captures stdout into the variable" }
            },
            "required": ["kind", "name", "command"]
        },
        "action_var_file": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "var" },
                "name": { "type": "string", "description": "Variable name (must start with @ for runtime mutability)" },
                "file": { "type": "string", "description": "Read this file's contents into the variable (~ expanded)" }
            },
            "required": ["kind", "name", "file"]
        },
        "action_var_from": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "var" },
                "name": { "type": "string", "description": "Variable name (must start with @ for runtime mutability)" },
                "from": {
                    "oneOf": [
                        { "type": "string", "description": "Step ID whose stdout to capture" },
                        { "$ref": "#/definitions/step" }
                    ]
                }
            },
            "required": ["kind", "name", "from"]
        },
        "action_var_to": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "var" },
                "name": { "type": "string", "description": "Variable name (must start with @ for runtime mutability)" },
                "to": {
                    "oneOf": [
                        { "type": "string", "description": "Step ID to feed stdin to" },
                        { "$ref": "#/definitions/step" }
                    ]
                }
            },
            "required": ["kind", "name", "to"]
        },
        "action_cond": {
            "additionalProperties": false,
            "properties": {
                "kind": { "const": "cond" },
                "cmp": { "type": "string", "description": "Value to compare (substituted at runtime, e.g. {{@var}})" },
                "when": {
                    "type": "object",
                    "description": "Map of string keys to step ref(s). The key matching `cmp` after substitution is executed.",
                    "additionalProperties": { "$ref": "#/definitions/step_ref_or_array" }
                },
                "default": {
                    "$ref": "#/definitions/step_ref_or_array",
                    "description": "Step ref(s) to run when no `when` key matches (optional)"
                }
            },
            "required": ["kind", "cmp", "when"]
        },
        "path_spec": {
            "oneOf": [
                { "type": "string" },
                { "type": "array", "items": { "type": "string" } }
            ],
            "description": "Path or array of paths. Trailing / = directory."
        },
        "expand": {
            "description": "Control {{var}} substitution per-field. Default renders paths but leaves contents byte-exact. Shorthand `true` enables all; `false` disables all.",
            "oneOf": [
                { "type": "boolean" },
                {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "from":     { "type": "boolean", "default": true, "description": "Substitute {{...}} in the `from` path" },
                        "to":       { "type": "boolean", "default": true, "description": "Substitute {{...}} in the `to` path" },
                        "path":     { "type": "boolean", "default": true, "description": "Substitute {{...}} in the `path` field" },
                        "contents": { "type": "boolean", "default": false, "description": "Substitute {{...}} in file contents (bundle fs.copy)" }
                    }
                }
            ]
        },
        "condition": {
            "oneOf": [
                {
                    "type": "string",
                    "enum": ["skip", "overwrite", "append", "panic"]
                },
                {
                    "type": "object",
                    "required": ["execute"],
                    "additionalProperties": false,
                    "properties": {
                        "execute": {
                            "oneOf": [
                                { "type": "string", "description": "Step ID" },
                                { "$ref": "#/definitions/step" }
                            ]
                        }
                    }
                }
            ]
        }
    }
}
