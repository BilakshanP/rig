{
    // ── Top-level config ──
    "name": "My Dev Environment",
    "version": "1.0.0",
    "description": "Full example showing all rig features",

    "steps": [
        // ── Shell with on-success/on-failure/on-return ──
        {
            "id": "install-tools",
            "name": "Install dev tools",
            "description": "Install ripgrep, fzf, tmux",
            "action": {
                "kind": "shell",
                "commands": ["apt install -y ripgrep fzf tmux"],
                "dir": "~",
                "env": { "DEBIAN_FRONTEND": "noninteractive" }
            },
            "on-success": "link-configs",
            "on-failure": "handle-error",
            "on-return": {
                "1": {
                    "name": "retry message",
                    "action": { "kind": "shell", "commands": ["echo 'apt returned 1, retrying...'"] }
                },
                "_": "handle-error"
            },
            "then": [
                "link-configs",
                {
                    "name": "quick cleanup",
                    "action": { "kind": "shell", "commands": ["echo done"] }
                }
            ],
            "meta": {
                "optional": false,
                "fallible": false,
                "silent": ["stdout"]
            }
        },

        // ── Git with on-conflict ──
        {
            "id": "clone-dotfiles",
            "name": "Clone dotfiles",
            "action": {
                "kind": "git",
                "repo": "https://github.com/user/dotfiles.git",
                "dest": "~/.dotfiles",
                "on-conflict": "pull"       // skip (default), pull, fail
            }
        },

        // ── FS: symlink ──
        {
            "id": "link-configs",
            "name": "Symlink configs",
            "action": {
                "kind": "fs",
                "symlink": {
                    "from": "~/.dotfiles/.bashrc",
                    "to": "~/.bashrc"
                },
                "if-exists": "overwrite"
            }
        },

        // ── FS: create (multiple paths) ──
        {
            "id": "create-dirs",
            "name": "Create project dirs",
            "action": {
                "kind": "fs",
                "create": {
                    "path": ["~/projects/", "~/tmp/", "~/.config/devsetup/"],
                    "recurse": true
                },
                "if-exists": "skip"
            }
        },

        // ── FS: create with content ──
        {
            "id": "create-config",
            "name": "Create default config",
            "action": {
                "kind": "fs",
                "create": {
                    "path": "~/.config/devsetup/config.json",
                    "recurse": true,
                    "content": "{\n  \"theme\": \"dark\"\n}"
                },
                "if-exists": "skip"
            }
        },

        // ── FS: copy ──
        {
            "id": "copy-template",
            "name": "Copy template config",
            "action": {
                "kind": "fs",
                "copy": {
                    "from": "~/.dotfiles/template.conf",
                    "to": "~/.config/devsetup/config.conf"
                },
                "if-exists": { "execute": "handle-overwrite" },
                "if-not-exists": "panic"
            }
        },

        // ── FS: move ──
        {
            "id": "move-old-config",
            "name": "Move old config to backup",
            "action": {
                "kind": "fs",
                "move": {
                    "from": "~/.old-config",
                    "to": "~/.old-config.bak"
                },
                "if-not-exists": "skip"
            }
        },

        // ── FS: delete ──
        {
            "id": "delete-cache",
            "name": "Delete build cache",
            "action": {
                "kind": "fs",
                "delete": {
                    "path": "~/.cache/devsetup",
                    "recurse": true
                },
                "if-not-exists": "skip"
            }
        },

        // ── Optional steps (only run when referenced) ──
        {
            "id": "handle-error",
            "name": "Error handler",
            "action": { "kind": "shell", "commands": ["echo 'Something went wrong'"] },
            "meta": { "optional": true }
        },
        {
            "id": "handle-overwrite",
            "name": "Handle config overwrite",
            "action": { "kind": "shell", "commands": ["echo 'Config exists, backing up...'"] },
            "meta": { "optional": true, "fallible": true }
        }
    ]
}
